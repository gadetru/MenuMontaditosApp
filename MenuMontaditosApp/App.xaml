<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MenuMontaditosApp"
             xmlns:converters="clr-namespace:MenuMontaditosApp.Converters" 
             x:Class="MenuMontaditosApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>


            <!-- Aqui registramos los convertidores que usaremos en las vistas -->
            <converters:EstadoAColorConverter x:Key="EstadoAColor"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
