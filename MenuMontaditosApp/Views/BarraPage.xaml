<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MenuMontaditosApp.Views.BarraPage"
             Title="Barra">

    <!-- CABECERA -->
    <Grid Grid.Row="0" Margin="10,10,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Column="0"
           Text="Barra y caja"
           FontSize="24"
           FontAttributes="Bold"
           VerticalOptions="Center"
           HorizontalOptions="Center"/>

        <Button Grid.Column="1"
            Text="🛠 Productos"
            Clicked="GestionProductos_Click"
            HeightRequest="40"/>
    

    <!-- LISTA DE PEDIDOS -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Pedidos}">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- TARJETA DE CADA PEDIDO -->
                    <!-- El color del fondo lo saca del convertidor que ya teníamos del cocina -->
                    <Border Stroke="Gray"
                            StrokeThickness="1"
                            Margin="10"
                            Padding="10"
                            BackgroundColor="{Binding Estado, Converter={StaticResource EstadoAColor}}">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="5"/>
                        </Border.StrokeShape>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- NOMBRE, HORA Y ESTADO -->
                            <HorizontalStackLayout Grid.Row="0"
                                                   Margin="0,0,0,8">
                                <Label Text="{Binding Pedido.NombreCliente}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       Margin="0,0,10,0"/>
                                <Label Text="{Binding Pedido.FechaHora, StringFormat='{0:HH:mm}'}"
                                       FontSize="14"
                                       TextColor="Gray"
                                       Margin="0,0,10,0"/>
                                <Label Text="{Binding Estado}"
                                       FontSize="14"
                                       FontAttributes="Bold"/>
                            </HorizontalStackLayout>

                            <!-- PRODUCTOS DEL PEDIDO (sin checkbox aqui, solo lectura) -->
                            <CollectionView Grid.Row="1"
                                            ItemsSource="{Binding Pedido.Detalles}"
                                            Margin="0,0,0,8">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <HorizontalStackLayout Margin="0,2,0,2">
                                            <Label Text="{Binding Producto.Nombre}"
                                                   WidthRequest="150"/>
                                            <Label Text="{Binding Cantidad}"
                                                   Margin="8,0,0,0"/>
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <!-- BOTON ARCHIVAR -->
                            <HorizontalStackLayout Grid.Row="2"
                                                   HorizontalOptions="End">
                                <Button Text="Cobrado y entregado"
                                        Clicked="Archivar_Click"
                                        CommandParameter="{Binding}"
                                        WidthRequest="180"/>
                            </HorizontalStackLayout>

                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>